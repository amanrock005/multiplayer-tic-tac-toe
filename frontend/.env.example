# deployment/.env.example  — copy to .env and fill in values
# Never commit .env to version control

# Postgres
POSTGRES_PASSWORD=strong_random_password_here

# Nakama
NAKAMA_SERVER_KEY=your_server_key_here
NAKAMA_CONSOLE_PASSWORD=admin_console_password_here

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://YOUR_DOMAIN/v2/account/authenticate/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend (for Vite / Vercel)
VITE_NAKAMA_HOST=YOUR_SERVER_IP_OR_DOMAIN
VITE_NAKAMA_PORT=443
VITE_NAKAMA_USE_SSL=true
VITE_NAKAMA_SERVER_KEY=your_server_key_here
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
